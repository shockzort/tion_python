# Easy Breezy — конфигурация (скопируйте в .env и заполните).
# Все переменные сервера имеют префикс EB_.

# ── Сервер ──────────────────────────────────────────────────────────────
EB_HOST=0.0.0.0
EB_PORT=8000
EB_LOG_LEVEL=INFO
# Каталог логов; пусто — только stdout/journald
#EB_LOG_DIR=logs
# Каталог данных (SQLite, бэкапы)
EB_DATA_DIR=data
# Таймзона автоматизации/бэкапов (IANA-имя). По умолчанию системная;
# в docker-контейнере системная = UTC — задавать обязательно.
#EB_TIMEZONE=Europe/Moscow

# ── Фаза 1: BLE ─────────────────────────────────────────────────────────
# Dev-режим без железа: поднять N фейковых бризеров
#EB_FAKE_DEVICES=3

# ── Фаза 4: Умный дом Яндекса (заполняется при настройке навыка) ────────
#EB_YANDEX_CLIENT_ID=
#EB_YANDEX_CLIENT_SECRET=
#EB_YANDEX_SKILL_ID=
#EB_YANDEX_CALLBACK_TOKEN=

# ── Фаза 6: датчики ─────────────────────────────────────────────────────
#EB_MAGICAIR_EMAIL=
#EB_MAGICAIR_PASSWORD=
#EB_MQTT_HOST=
#EB_MQTT_PORT=1883
#EB_MQTT_USERNAME=
#EB_MQTT_PASSWORD=
