# Tion Python — пример конфигурации
# Скопируйте этот файл в .env и заполните реальными значениями

# База данных
DB_PATH=devices.db

# Яндекс OAuth API
YANDEX_OAUTH_INFO_URL=https://login.yandex.ru/info

# Яндекс Smart Home callback
# Получить в личном кабинете разработчика Яндекс Диалогов
YANDEX_SKILL_ID=your_skill_id_here
YANDEX_CALLBACK_TOKEN=your_oauth_token_here

# HTTP сервер
HOST=0.0.0.0
PORT=8000
DEBUG=false

# BLE операции
BLE_OPERATION_TIMEOUT=10.0

# MQTT (опционально)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=sensors

# Логирование
LOG_DIR=/var/log/tion
