# nginx на VPS: TLS-терминация + прокси в frps-туннель (localhost:18000).
# Вариант TLS решается в Фазе 4 (§6 плана):
#   A) IP-сертификат Let's Encrypt (профиль shortlived) — если консоль Яндекса примет IP;
#   B) бесплатный поддомен DuckDNS + certbot (основной путь).
# После выбора: certbot --nginx -d <домен> (или ACME-профиль shortlived для IP).

upstream easy_breezy {
    server 127.0.0.1:18000;
    keepalive 8;   # быстрый HEAD-пинг Яндекса
}

server {
    listen 443 ssl;
    http2 on;
    server_name <домен-или-IP>;

    ssl_certificate     /etc/letsencrypt/live/<домен>/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/<домен>/privkey.pem;

    location / {
        proxy_pass http://easy_breezy;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        # WebSocket (/ws)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 120s;
    }
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ""      close;
}

server {
    listen 80;
    server_name <домен-или-IP>;
    return 301 https://$host$request_uri;
}
