# nginx на VPS: TLS-терминация + прокси в frps-туннель (localhost:18000).
# TLS — поддомен DuckDNS + certbot certonly (ADR-0006, docs/yandex-setup.md).

upstream easy_breezy {
    server 127.0.0.1:18000;
    keepalive 8;   # быстрый HEAD-пинг Яндекса
}

server {
    # http2 параметром в listen — работает и на nginx < 1.25.1 (Debian/Ubuntu
    # из коробки); на ≥ 1.25.1 это deprecated-синтаксис, но валидный.
    listen 443 ssl http2;
    server_name <домен-или-IP>;

    ssl_certificate     /etc/letsencrypt/live/<домен>/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/<домен>/privkey.pem;

    location / {
        proxy_pass http://easy_breezy;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        # WebSocket (/api/ws)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 120s;
    }
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ""      close;
}

server {
    listen 80;
    server_name <домен-или-IP>;
    return 301 https://$host$request_uri;
}
